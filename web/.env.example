API_SECRET_KEY=
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_EXTENSION_CLIENT_ID=
ALLOWED_ORIGINS=

# Path to the SQLite DB file.
# In production (Railway), point to the persistent volume: DB_PATH=/data/sqlite.db
# Leave empty for local dev (defaults to ./sqlite.db in the web/ directory)
DB_PATH=

# Waitlist confirmation emails (Resend — free tier: 3k emails/month)
# Sign up at https://resend.com → API Keys → Create key with Sending access
RESEND_API_KEY=
# Sender address. Use onboarding@resend.dev while testing (no DNS setup needed).
# Switch to your own domain once verified in the Resend dashboard.
EMAIL_FROM=Nightstand <hi@yournightstand.com>
