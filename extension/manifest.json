{
  "manifest_version": 3,
  "name": "Nightstand",
  "description": "Save the current page to your Nightstand weekly reading list.",
  "version": "0.2.0",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save this page",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html"
}
